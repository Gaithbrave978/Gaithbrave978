class DiceLoss(nn.Module):
    """Soft multi-class Dice loss."""

    def __init__(self, smooth: float = 1e-5):
        super().__init__()
        self.smooth = smooth

    def forward(
        self,
        logits: torch.Tensor,
        targets: torch.Tensor,
    ) -> torch.Tensor:
        probs = torch.softmax(logits, dim=1)
        oh    = F.one_hot(targets.long(), probs.size(1)).permute(0, 4, 1, 2, 3).float()
        dims  = (0, 2, 3, 4)
        inter = (probs * oh).sum(dims)
        union = (probs + oh).sum(dims)
        return 1.0 - ((2 * inter + self.smooth) / (union + self.smooth)).mean()


class FocalLoss(nn.Module):
    """Focal loss — down-weights easy examples to focus on hard ones."""

    def __init__(
        self,
        gamma: float = 2.0,
        weight: Optional[torch.Tensor] = None,
    ):
        super().__init__()
        self.gamma  = gamma
        self.weight = weight

    def forward(
        self,
        logits: torch.Tensor,
        targets: torch.Tensor,
    ) -> torch.Tensor:
        ce  = F.cross_entropy(logits, targets, weight=self.weight, reduction="none")
        p_t = torch.exp(-ce)
        return ((1 - p_t) ** self.gamma * ce).mean()


class CombinedSegLoss(nn.Module):
    """Dice (0.5) + Cross-Entropy (0.3) + Focal (0.2) combined loss."""

    def __init__(
        self,
        dice_w: float = 0.5,
        ce_w:   float = 0.3,
        focal_w: float = 0.2,
    ):
        super().__init__()
        self.dice  = DiceLoss()
        self.focal = FocalLoss()
        self.w     = (dice_w, ce_w, focal_w)

    def forward(
        self,
        logits: torch.Tensor,
        targets: torch.Tensor,
    ) -> torch.Tensor:
        return (
            self.w[0] * self.dice(logits, targets)
            + self.w[1] * F.cross_entropy(logits, targets.long())
            + self.w[2] * self.focal(logits, targets.long())
        )


