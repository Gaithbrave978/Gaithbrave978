  1366 def _hu_to_uint8(vol: np.ndarray, wmin=-20, wmax=80) -> np.ndarray:
  1367     return ((np.clip(vol, wmin, wmax) - wmin) / (wmax - wmin) * 255).astype(np.uint8)
