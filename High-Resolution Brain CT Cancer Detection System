    98 def apply_hu_window(volume: np.ndarray, wmin: float, wmax: float) -> np.ndarray:
    99     """Clip HU values to [wmin, wmax] and scale linearly to [0, 1]."""
   100     return (np.clip(volume, wmin, wmax) - wmin) / (wmax - wmin)
   101
   102
   103 def multi_channel_window(volume: np.ndarray) -> np.ndarray:
   104     """
   105     Produce a 5-channel float32 representation of a single HU volume.
   106     Each channel uses a clinically meaningful window — analogous to
   107     different MRI sequences in terms of tissue contrast.
   108     Output shape: (5, D, H, W)
   109     """
   110     channels = [
   111         apply_hu_window(volume, lo, hi)
   112         for lo, hi in HU_WINDOWS.values()
   113     ]
   114     return np.stack(channels, axis=0).astype(np.float32)
   115
   116
   117 def strip_skull(
   118     volume: np.ndarray,
   119     hu_min: float = -20,
   120     hu_max: float = 80,
   121 ) -> Tuple[np.ndarray, np.ndarray]:
   122     """
   123     Morphology-based skull stripping.
   124     Returns (stripped_volume, binary_brain_mask).
   125     """
   126     mask = np.logical_and(volume >= hu_min, volume <= hu_max)
   127     mask = morphology.remove_small_objects(mask, min_size=5_000)
   128
   129     filled = np.zeros_like(mask)
   130     for i in range(mask.shape[0]):
   131         filled[i] = ndimage.binary_fill_holes(mask[i])
   132
   133     labeled = measure.label(filled)
   134     props   = measure.regionprops(labeled)
   135     if props:
   136         largest = max(props, key=lambda p: p.area)
   137         mask = (labeled == largest.label)
   138     else:
   139         mask = filled
   140
   141     stripped = volume.copy().astype(np.float32)
   142     stripped[~mask] = -1000
   143     return stripped, mask.astype(np.uint8)
