def dice_coefficient(
    pred: np.ndarray,
    target: np.ndarray,
    smooth: float = 1e-6,
) -> float:
    p = pred.astype(bool).flatten()
    t = target.astype(bool).flatten()
    return float((2 * (p & t).sum() + smooth) / (p.sum() + t.sum() + smooth))


def hausdorff_distance_95(
    pred: np.ndarray,
    target: np.ndarray,
    voxel_spacing: Tuple[float, ...] = (1.0, 1.0, 1.0),
) -> float:
    """95th-percentile Hausdorff distance in millimetres."""
    from scipy.spatial import cKDTree
    pred_pts   = np.argwhere(pred   > 0).astype(float) * np.array(voxel_spacing)
    target_pts = np.argwhere(target > 0).astype(float) * np.array(voxel_spacing)
    if pred_pts.size == 0 or target_pts.size == 0:
        return float("nan")
    d_pt = cKDTree(target_pts).query(pred_pts,  workers=-1)[0]
    d_tp = cKDTree(pred_pts).query(target_pts,  workers=-1)[0]
    return float(max(np.percentile(d_pt, 95), np.percentile(d_tp, 95)))


def sensitivity_specificity(
    pred: np.ndarray,
    target: np.ndarray,
) -> Dict[str, float]:
    p  = pred.astype(bool).flatten()
    t  = target.astype(bool).flatten()
    tp = (p & t).sum();  tn = (~p & ~t).sum()
    fp = (p & ~t).sum(); fn = (~p &  t).sum()
    return dict(
        sensitivity = float(tp / (tp + fn + 1e-8)),
        specificity = float(tn / (tn + fp + 1e-8)),
        ppv         = float(tp / (tp + fp + 1e-8)),
        npv         = float(tn / (tn + fn + 1e-8)),
    )


def evaluate_segmentation(
    pred_mask: np.ndarray,
    true_mask: np.ndarray,
    spacing: Tuple[float, ...] = (1., 1., 1.),
) -> Dict:
    results = {}
    for c, name in enumerate(SEG_NAMES):
        if c == 0:
            continue
        p = (pred_mask == c).astype(np.uint8)
        t = (true_mask == c).astype(np.uint8)
        results[name] = dict(
            dice = dice_coefficient(p, t),
            hd95 = hausdorff_distance_95(p, t, spacing),
            **sensitivity_specificity(p, t),
        )
    return results


def evaluate_classification(
    y_true: np.ndarray,
    y_pred: np.ndarray,
    y_prob: np.ndarray,
) -> Dict:
    from sklearn.metrics import (
        cohen_kappa_score, confusion_matrix,
        classification_report, roc_auc_score,
    )
    cm     = confusion_matrix(y_true, y_pred)
    report = classification_report(y_true, y_pred,
                                   target_names=CLS_NAMES, output_dict=True)
    kappa  = cohen_kappa_score(y_true, y_pred, weights="quadratic")
    try:
        auc = (roc_auc_score(y_true, y_prob[:, 1])
               if y_prob.shape[1] == 2
               else roc_auc_score(y_true, y_prob,
                                  multi_class="ovr", average="macro"))
    except ValueError:
        auc = float("nan")
    return dict(confusion_matrix=cm, report=report,
                quadratic_kappa=kappa, roc_auc=auc,
                accuracy=report["accuracy"])


def expected_calibration_error(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    n_bins: int = 15,
) -> float:
    confidences = y_prob.max(axis=1)
    predictions = y_prob.argmax(axis=1)
    accuracies  = (predictions == y_true).astype(float)
    ece = 0.0
    for lo, hi in zip(
        np.linspace(0, 1, n_bins + 1)[:-1],
        np.linspace(0, 1, n_bins + 1)[1:],
    ):
        mask = (confidences >= lo) & (confidences < hi)
        if mask.sum():
            ece += mask.mean() * abs(accuracies[mask].mean()
                                     - confidences[mask].mean())
    return float(ece)


