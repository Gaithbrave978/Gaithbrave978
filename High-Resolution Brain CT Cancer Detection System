   146 def resample_isotropic(
   147     volume: np.ndarray,
   148     current_spacing: Tuple[float, ...],
   149     target_spacing: float = 1.0,
   150 ) -> np.ndarray:
   151     """Resample a volume to isotropic voxel spacing via cubic zoom."""
   152     zoom_factors = [s / target_spacing for s in current_spacing]
   153     return ndimage.zoom(volume, zoom_factors, order=1)
