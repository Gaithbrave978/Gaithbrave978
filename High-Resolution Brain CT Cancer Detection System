class EMA:
    """Exponential Moving Average of model weights for lower-variance inference."""

    def __init__(self, model: nn.Module, decay: float = 0.9999):
        self.model = copy.deepcopy(model).eval()
        self.decay = decay

    @torch.no_grad()
    def update(self, model: nn.Module):
        for ep, mp in zip(self.model.parameters(), model.parameters()):
            ep.data.mul_(self.decay).add_(mp.data, alpha=1 - self.decay)


class Trainer:
    """
    Full training loop with:
      · Mixed-precision (AMP)
      · Cosine annealing with warm restarts
      · EMA weight averaging
      · Early stopping
      · Best-checkpoint saving

    Parameters
    ----------
    model           : BrainCTEnsemble instance
    train_loader    : DataLoader yielding {image, seg_mask, label}
    val_loader      : DataLoader 
    device          : 'cuda' or 'cpu'
    lr              : peak learning rate
    weight_decay    : AdamW L2 regularisation
    max_epochs      : hard ceiling on training epochs
    patience        : early-stopping patience
    checkpoint_path : where to save the best checkpoint
    """

    def __init__(
        self,
        model: BrainCTEnsemble,
        train_loader: DataLoader,
        val_loader: DataLoader,
        device: str = "cuda",
        lr: float = 3e-4,
        weight_decay: float = 1e-5,
        max_epochs: int = 200,
        patience: int = 25,
        checkpoint_path: str = "best_brain_ct_model.pth",
    ):
        self.model    = model.to(device)
        self.ema      = EMA(model)
        self.train_dl = train_loader
        self.val_dl   = val_loader
        self.device   = device
        self.epochs   = max_epochs
        self.patience = patience
        self.ckpt     = checkpoint_path

        self.seg_loss  = CombinedSegLoss()
        self.cls_loss  = FocalLoss(gamma=2.0)
        self.fuse_loss = FocalLoss(gamma=2.0)

        self.opt    = AdamW(model.parameters(), lr=lr,
                            weight_decay=weight_decay, betas=(0.9, 0.999))
        self.sched  = CosineAnnealingWarmRestarts(self.opt, T_0=50, T_mult=2,
                                                  eta_min=lr * 0.01)
        self.scaler = GradScaler()

        self.best_val_loss     = float("inf")
        self.epochs_no_improve = 0
        self.history: Dict[str, list] = {
            "train_loss": [], "val_loss": [],
            "val_auc":    [], "val_kappa": [],
        }

    def _run_epoch(self, loader: DataLoader, train: bool) -> Dict[str, float]:
        self.model.train(train)
        seg_tot = cls_tot = fused_tot = total = 0.0
        all_preds, all_labels, all_probs = [], [], []

        ctx = torch.enable_grad if train else torch.no_grad
        with ctx():
            for batch in tqdm(loader, leave=False,
                              desc="train" if train else " val "):
                imgs    = batch["image"].to(self.device)
                seg_tgt = batch["seg_mask"].to(self.device)
                cls_tgt = batch["label"].to(self.device)

                with autocast():
                    seg_log, cls_log, fused = self.model(imgs)
                    l_seg   = self.seg_loss(seg_log, seg_tgt)
                    l_cls   = self.cls_loss(cls_log, cls_tgt)
                    l_fused = self.fuse_loss(fused,  cls_tgt)
                    loss    = 0.4 * l_seg + 0.3 * l_cls + 0.3 * l_fused

                if train:
                    self.opt.zero_grad()
                    self.scaler.scale(loss).backward()
                    self.scaler.unscale_(self.opt)
                    nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)
                    self.scaler.step(self.opt)
                    self.scaler.update()
                    self.ema.update(self.model)

                B = imgs.size(0)
                seg_tot   += l_seg.item()   * B
                cls_tot   += l_cls.item()   * B
                fused_tot += l_fused.item() * B
                total     += loss.item()    * B

                probs = torch.softmax(fused, 1).detach().cpu().numpy()
                all_probs.append(probs)
                all_preds.append(probs.argmax(1))
                all_labels.append(cls_tgt.cpu().numpy())

        N   = len(loader.dataset)
        prb = np.concatenate(all_probs)
        prd = np.concatenate(all_preds)
        lbl = np.concatenate(all_labels)
        met = evaluate_classification(lbl, prd, prb)
        ece = expected_calibration_error(lbl, prb)

        return dict(loss=total/N, loss_seg=seg_tot/N, loss_cls=cls_tot/N,
                    loss_fused=fused_tot/N, accuracy=met["accuracy"],
                    roc_auc=met["roc_auc"], kappa=met["quadratic_kappa"], ece=ece)

    def fit(self) -> Dict[str, list]:
        for epoch in range(1, self.epochs + 1):
            t0 = time.time()
            tr = self._run_epoch(self.train_dl, train=True)
            va = self._run_epoch(self.val_dl,   train=False)
            self.sched.step()

            self.history["train_loss"].append(tr["loss"])
            self.history["val_loss"].append(va["loss"])
            self.history["val_auc"].append(va["roc_auc"])
            self.history["val_kappa"].append(va["kappa"])

            print(
                f"Epoch {epoch:03d}/{self.epochs}  "
                f"loss tr={tr['loss']:.4f} va={va['loss']:.4f}  "
                f"acc={va['accuracy']:.4f}  AUC={va['roc_auc']:.4f}  "
                f"κ={va['kappa']:.4f}  ECE={va['ece']:.4f}  "
                f"[{time.time()-t0:.1f}s]"
            )

            if va["loss"] < self.best_val_loss:
                self.best_val_loss     = va["loss"]
                self.epochs_no_improve = 0
                torch.save(dict(epoch=epoch, model=self.model.state_dict(),
                                ema=self.ema.model.state_dict(),
                                optimizer=self.opt.state_dict(),
                                metrics=va), self.ckpt)
                print(f"  ✓ checkpoint saved  (val_loss={va['loss']:.4f})")
            else:
                self.epochs_no_improve += 1
                if self.epochs_no_improve >= self.patience:
                    print(f"  Early stopping at epoch {epoch}.")
                    break

        ckpt = torch.load(self.ckpt, map_location=self.device)
        self.model.load_state_dict(ckpt["model"])
        print(f"\nTraining complete.  Best val loss: {self.best_val_loss:.4f}")
        return self.history


