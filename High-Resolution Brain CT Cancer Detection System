class BrainCTDataset(Dataset):
    """
    Torch Dataset that reads from a JSON manifest:

    [
      {
        "id":      "case_001",
        "ct":      "path/to/volume.npy",   (D, H, W) float32 HU
        "seg":     "path/to/mask.npy",     (D, H, W) uint8 {0,1,2}
        "label":   2,                      class index
        "spacing": [1.0, 1.0, 1.0]         voxel spacing in mm
      }, ...
    ]

    Compatible with BraTS, TCGA-GBM, and LIDC-IDRI naming conventions.
    Foreground-oversampled patch extraction ensures rare tumour voxels
    are seen during training.
    """

    def __init__(
        self,
        manifest_path: str,
        patch_size: int = 64,
        patches_per_volume: int = 8,
        augment: bool = True,
        foreground_oversample: float = 0.67,
    ):
        with open(manifest_path, encoding="utf-8") as f:
            self.records = json.load(f)
        self.patch_size = patch_size
        self.n_patches  = patches_per_volume
        self.augment    = augment
        self.fg_rate    = foreground_oversample
        self.augmentor  = CTAugmentor(p=0.5)

    def __len__(self) -> int:
        return len(self.records) * self.n_patches

    def _load(self, idx: int) -> Dict:
        rec     = self.records[idx // self.n_patches]
        hu      = np.load(rec["ct"]).astype(np.float32)
        seg     = np.load(rec["seg"]).astype(np.uint8)
        spacing = tuple(rec.get("spacing", [1.0, 1.0, 1.0]))
        hu, mask = strip_skull(hu)
        hu       = z_score_normalize(hu, mask)
        return dict(vol5=multi_channel_window(hu), seg=seg,
                    label=int(rec["label"]), spacing=spacing)

    def _sample_patch(
        self,
        vol5: np.ndarray,
        seg: np.ndarray,
    ) -> Tuple[np.ndarray, np.ndarray]:
        D, H, W = vol5.shape[1:]
        ps      = self.patch_size
        if np.random.rand() < self.fg_rate and (seg > 0).any():
            fc = np.argwhere(seg > 0)
            c  = fc[np.random.randint(len(fc))]
        else:
            c = [np.random.randint(D), np.random.randint(H), np.random.randint(W)]

        d0 = int(np.clip(c[0] - ps // 2, 0, max(0, D - ps)))
        h0 = int(np.clip(c[1] - ps // 2, 0, max(0, H - ps)))
        w0 = int(np.clip(c[2] - ps // 2, 0, max(0, W - ps)))

        vp = vol5[:, d0:d0+ps, h0:h0+ps, w0:w0+ps]
        sp = seg[    d0:d0+ps, h0:h0+ps, w0:w0+ps]
        pd, ph, pw = ps - vp.shape[1], ps - vp.shape[2], ps - vp.shape[3]
        if pd or ph or pw:
            vp = np.pad(vp, [(0,0),(0,pd),(0,ph),(0,pw)])
            sp = np.pad(sp,         [(0,pd),(0,ph),(0,pw)])
        return vp, sp

    def __getitem__(self, idx: int) -> Dict[str, torch.Tensor]:
        data      = self._load(idx)
        vp, sp    = self._sample_patch(data["vol5"], data["seg"])
        vol_t     = torch.from_numpy(vp.copy()).float()
        seg_t     = torch.from_numpy(sp.copy()).long()
        if self.augment:
            vol_t, seg_f = self.augmentor(vol_t.unsqueeze(0),
                                          seg_t.unsqueeze(0).float())
            vol_t = vol_t.squeeze(0)
            seg_t = seg_f.squeeze(0).long()
        return dict(image=vol_t, seg_mask=seg_t,
                    label=torch.tensor(data["label"], dtype=torch.long))


