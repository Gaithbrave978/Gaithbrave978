   702 class GradCAM3D:
   703     """
   704     Gradient-weighted Class Activation Mapping for 3-D CNNs.
   705
   706     Usage
   707     -----
   708     gcam    = GradCAM3D(model, target_layer=model.classifier.stages[-1])
   709     heatmap = gcam(input_tensor, class_idx=2)   # 2 = High-Grade GBM
   710     heatmap shape: (D, H, W), values in [0, 1]
   711     """
   712
   713     def __init__(self, model: nn.Module, target_layer: nn.Module):
   714         self.model        = model
   715         self.target_layer = target_layer
   716         self._gradients: Optional[torch.Tensor] = None
   717         self._activations: Optional[torch.Tensor] = None
   718         target_layer.register_forward_hook(
   719             lambda _, __, o: setattr(self, "_activations", o.detach()))
   720         target_layer.register_full_backward_hook(
   721             lambda _, __, g: setattr(self, "_gradients", g[0].detach()))
   722
   723     @torch.enable_grad()
   724     def __call__(
   725         self,
   726         x: torch.Tensor,
   727         class_idx: Optional[int] = None,
   728     ) -> np.ndarray:
   729         self.model.eval()
   730         x = x.requires_grad_(True)
   731         logits = self.model(x)
   732         if isinstance(logits, tuple):
   733             logits = logits[2]
   734         if class_idx is None:
   735             class_idx = int(logits.argmax(dim=1).item())
   736         self.model.zero_grad()
   737         logits[0, class_idx].backward()
   738         weights = self._gradients.mean(dim=[2, 3, 4], keepdim=True)
   739         cam     = F.relu((weights * self._activations).sum(1, keepdim=True))
   740         cam     = F.interpolate(cam, size=x.shape[2:],
   741                                 mode="trilinear", align_corners=False)
   742         cam     = cam.squeeze().cpu().numpy()
   743         cam_max = cam.max()
   744         return cam / (cam_max + 1e-8)
   745
   746
   747 class SegGradCAM3D:
   748     """Grad-CAM adapted for the segmentation head."""
   749
   750     def __init__(self, model: nn.Module, target_layer: nn.Module):
   751         self.model        = model
   752         self.target_layer = target_layer
   753         self._gradients: Optional[torch.Tensor] = None
   754         self._activations: Optional[torch.Tensor] = None
   755         target_layer.register_forward_hook(
   756             lambda _, __, o: setattr(self, "_activations", o.detach()))
   757         target_layer.register_full_backward_hook(
   758             lambda _, __, g: setattr(self, "_gradients", g[0].detach()))
   759
   760     @torch.enable_grad()
   761     def __call__(
   762         self,
   763         x: torch.Tensor,
   764         seg_class: int = 2,
   765     ) -> np.ndarray:
   766         self.model.eval()
   767         x          = x.requires_grad_(True)
   768         seg_log, *_ = self.model(x)
   769         self.model.zero_grad()
   770         seg_log[:, seg_class].mean().backward()
   771         weights = self._gradients.mean(dim=[2, 3, 4], keepdim=True)
   772         cam     = F.relu((weights * self._activations).sum(1, keepdim=True))
   773         cam     = F.interpolate(cam, size=x.shape[2:],
   774                                 mode="trilinear", align_corners=False)
   775         cam     = cam.squeeze().cpu().numpy()
   776         return cam / (cam.max() + 1e-8)
