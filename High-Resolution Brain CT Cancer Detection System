   409 class AttentionUNet3D(nn.Module):
   410     """
   411     3-D Attention U-Net with Transformer bottleneck.
   412
   413     Input  : (B, in_channels, D, H, W)
   414     Output : (B, n_classes, D, H, W)  — voxel-wise logits
   415
   416     Classes
   417     -------
   418     0  background
   419     1  oedema / infiltration zone
   420     2  enhancing tumour core
   421     """
   422
   423     def __init__(
   424         self,
   425         in_channels: int = 5,
   426         n_classes: int = 3,
   427         base_ch: int = 32,
   428     ):
   429         super().__init__()
   430         c = base_ch
   431         self.enc1 = EncoderBlock(in_channels, c)
   432         self.enc2 = EncoderBlock(c,    c * 2)
   433         self.enc3 = EncoderBlock(c * 2, c * 4)
   434         self.enc4 = EncoderBlock(c * 4, c * 8)
   435         self.bottleneck = nn.Sequential(
   436             ConvBnRelu(c * 8, c * 16),
   437             ResidualBlock(c * 16),
   438             TransformerBottleneck(c * 16),
   439         )
   440         self.dec4 = DecoderBlock(c * 16, c * 8,  c * 8)
   441         self.dec3 = DecoderBlock(c * 8,  c * 4,  c * 4)
   442         self.dec2 = DecoderBlock(c * 4,  c * 2,  c * 2)
   443         self.dec1 = DecoderBlock(c * 2,  c,      c)
   444         self.head = nn.Conv3d(c, n_classes, 1)
   445         self._init_weights()
   446
   447     def _init_weights(self):
   448         for m in self.modules():
   449             if isinstance(m, (nn.Conv3d, nn.ConvTranspose3d)):
   450                 nn.init.kaiming_normal_(m.weight, nonlinearity="leaky_relu")
   451                 if m.bias is not None:
   452                     nn.init.zeros_(m.bias)
   453             elif isinstance(m, nn.Linear):
   454                 nn.init.trunc_normal_(m.weight, std=0.02)
   455                 if m.bias is not None:
   456                     nn.init.zeros_(m.bias)
   457
   458     def forward(self, x: torch.Tensor) -> torch.Tensor:
   459         x, s1 = self.enc1(x)
   460         x, s2 = self.enc2(x)
   461         x, s3 = self.enc3(x)
   462         x, s4 = self.enc4(x)
   463         x     = self.bottleneck(x)
   464         x     = self.dec4(x, s4)
   465         x     = self.dec3(x, s3)
   466         x     = self.dec2(x, s2)
   467         x     = self.dec1(x, s1)
   468         return self.head(x)
   469
