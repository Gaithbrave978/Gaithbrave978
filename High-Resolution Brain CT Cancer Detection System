   297 class SEBlock3D(nn.Module):
   298     """3-D Squeeze-and-Excitation channel attention."""
   299
   300     def __init__(self, ch: int, ratio: int = 4):
   301         super().__init__()
   302         self.se = nn.Sequential(
   303             nn.AdaptiveAvgPool3d(1),
   304             nn.Flatten(),
   305             nn.Linear(ch, max(1, ch // ratio)),
   306             nn.SiLU(),
   307             nn.Linear(max(1, ch // ratio), ch),
   308             nn.Sigmoid(),
   309         )
   310
   311     def forward(self, x: torch.Tensor) -> torch.Tensor:
   312         w = self.se(x).view(x.size(0), x.size(1), 1, 1, 1)
   313         return x * w
