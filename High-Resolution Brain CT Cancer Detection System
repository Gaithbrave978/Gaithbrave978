   316 class AttentionGate(nn.Module):
   317     """
   318     Spatial attention gate (Oktay et al., Attention U-Net, 2018).
   319     Suppresses irrelevant skip-connection activations in the decoder.
   320     """
   321
   322     def __init__(self, F_g: int, F_l: int, F_int: int):
   323         super().__init__()
   324         self.W_g = nn.Sequential(
   325             nn.Conv3d(F_g, F_int, 1, bias=True),
   326             nn.InstanceNorm3d(F_int, affine=True),
   327         )
   328         self.W_x = nn.Sequential(
   329             nn.Conv3d(F_l, F_int, 1, bias=True),
   330             nn.InstanceNorm3d(F_int, affine=True),
   331         )
   332         self.psi = nn.Sequential(
   333             nn.Conv3d(F_int, 1, 1, bias=True),
   334             nn.InstanceNorm3d(1, affine=True),
   335             nn.Sigmoid(),
   336         )
   337         self.relu = nn.ReLU(inplace=True)
   338
   339     def forward(self, g: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
   340         g1 = self.W_g(g)
   341         x1 = self.W_x(x)
   342         if g1.shape != x1.shape:
   343             g1 = F.interpolate(g1, size=x1.shape[2:],
   344                                mode="trilinear", align_corners=False)
   345         return x * self.psi(self.relu(g1 + x1))
