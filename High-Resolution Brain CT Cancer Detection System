   156 def z_score_normalize(
   157     volume: np.ndarray,
   158     mask: Optional[np.ndarray] = None,
   159 ) -> np.ndarray:
   160     """Z-score normalisation, optionally restricted to brain-mask voxels."""
   161     vals  = volume[mask > 0] if mask is not None else volume.flatten()
   162     mu    = vals.mean()
   163     sigma = vals.std() + 1e-8
   164     return (volume - mu) / sigma
