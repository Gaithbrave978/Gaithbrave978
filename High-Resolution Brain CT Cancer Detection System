   393 class DecoderBlock(nn.Module):
   394     def __init__(self, in_ch: int, skip_ch: int, out_ch: int):
   395         super().__init__()
   396         self.up   = nn.ConvTranspose3d(in_ch, in_ch // 2, 2, stride=2)
   397         self.ag   = AttentionGate(in_ch // 2, skip_ch, out_ch // 2)
   398         self.conv = nn.Sequential(
   399             ConvBnRelu(in_ch // 2 + skip_ch, out_ch),
   400             ResidualBlock(out_ch),
   401         )
   402
   403     def forward(self, x: torch.Tensor, skip: torch.Tensor) -> torch.Tensor:
   404         x    = self.up(x)
   405         skip = self.ag(x, skip)
   406         return self.conv(torch.cat([x, skip], dim=1))
   407
