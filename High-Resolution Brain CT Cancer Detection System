   983
   984 class EMA:
   985     """Exponential Moving Average of model weights for lower-variance inference."""
   986
   987     def __init__(self, model: nn.Module, decay: float = 0.9999):
   988         self.model = copy.deepcopy(model).eval()
   989         self.decay = decay
   990
   991     @torch.no_grad()
   992     def update(self, model: nn.Module):
   993         for ep, mp in zip(self.model.parameters(), model.parameters()):
   994             ep.data.mul_(self.decay).add_(mp.data, alpha=1 - self.decay)
   995
   996
   997 class Trainer:
   998     """
   999     Full training loop with:
  1000       · Mixed-precision (AMP)
  1001       · Cosine annealing with warm restarts
  1002       · EMA weight averaging
  1003       · Early stopping
  1004       · Best-checkpoint saving
  1005
  1006     Parameters
  1007     ----------
  1008     model           : BrainCTEnsemble instance
  1009     train_loader    : DataLoader yielding {image, seg_mask, label}
  1010     val_loader      : DataLoader
  1011     device          : 'cuda' or 'cpu'
  1012     lr              : peak learning rate
  1013     weight_decay    : AdamW L2 regularisation
  1014     max_epochs      : hard ceiling on training epochs
  1015     patience        : early-stopping patience
  1016     checkpoint_path : where to save the best checkpoint
  1017     """
  1018
  1019     def __init__(
  1020         self,
  1021         model: BrainCTEnsemble,
  1022         train_loader: DataLoader,
  1023         val_loader: DataLoader,
  1024         device: str = "cuda",
  1025         lr: float = 3e-4,
  1026         weight_decay: float = 1e-5,
  1027         max_epochs: int = 200,
  1028         patience: int = 25,
  1029         checkpoint_path: str = "best_brain_ct_model.pth",
  1030     ):
  1031         self.model    = model.to(device)
  1032         self.ema      = EMA(model)
  1033         self.train_dl = train_loader
  1034         self.val_dl   = val_loader
  1035         self.device   = device
  1036         self.epochs   = max_epochs
  1037         self.patience = patience
  1038         self.ckpt     = checkpoint_path
  1039
  1040         self.seg_loss  = CombinedSegLoss()
  1041         self.cls_loss  = FocalLoss(gamma=2.0)
  1042         self.fuse_loss = FocalLoss(gamma=2.0)
  1043
  1044         self.opt    = AdamW(model.parameters(), lr=lr,
  1045                             weight_decay=weight_decay, betas=(0.9, 0.999))
  1046         self.sched  = CosineAnnealingWarmRestarts(self.opt, T_0=50, T_mult=2,
  1047                                                    eta_min=lr * 0.01)
  1048         self.scaler = GradScaler()
  1049
  1050         self.best_val_loss     = float("inf")
  1051         self.epochs_no_improve = 0
  1052         self.history: Dict[str, list] = {
  1053             "train_loss": [], "val_loss": [],
  1054             "val_auc":    [], "val_kappa": [],
  1055         }
  1056
  1057     def _run_epoch(self, loader: DataLoader, train: bool) -> Dict[str, float]:
  1058         self.model.train(train)
  1059         seg_tot = cls_tot = fused_tot = total = 0.0
  1060         all_preds, all_labels, all_probs = [], [], []
  1061
  1062         ctx = torch.enable_grad if train else torch.no_grad
  1063         with ctx():
  1064             for batch in tqdm(loader, leave=False,
  1065                                desc="train" if train else " val "):
  1066                 imgs    = batch["image"].to(self.device)
  1067                 seg_tgt = batch["seg_mask"].to(self.device)
  1068                 cls_tgt = batch["label"].to(self.device)
  1069
  1070                 with autocast():
  1071                     seg_log, cls_log, fused = self.model(imgs)
  1072                     l_seg   = self.seg_loss(seg_log, seg_tgt)
  1073                     l_cls   = self.cls_loss(cls_log, cls_tgt)
  1074                     l_fused = self.fuse_loss(fused,  cls_tgt)
  1075                     loss    = 0.4 * l_seg + 0.3 * l_cls + 0.3 * l_fused
  1076
  1077                 if train:
  1078                     self.opt.zero_grad()
  1079                     self.scaler.scale(loss).backward()
  1080                     self.scaler.unscale_(self.opt)
  1081                     nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)
  1082                     self.scaler.step(self.opt)
  1083                     self.scaler.update()
  1084                     self.ema.update(self.model)
  1085
  1086                 B = imgs.size(0)
  1087                 seg_tot   += l_seg.item()   * B
  1088                 cls_tot   += l_cls.item()   * B
  1089                 fused_tot += l_fused.item() * B
  1090                 total     += loss.item()    * B
  1091
  1092                 probs = torch.softmax(fused, 1).detach().cpu().numpy()
  1093                 all_probs.append(probs)
  1094                 all_preds.append(probs.argmax(1))
  1095                 all_labels.append(cls_tgt.cpu().numpy())
  1096
  1097         N   = len(loader.dataset)
  1098         prb = np.concatenate(all_probs)
  1099         prd = np.concatenate(all_preds)
  1100         lbl = np.concatenate(all_labels)
  1101         met = evaluate_classification(lbl, prd, prb)
  1102         ece = expected_calibration_error(lbl, prb)
  1103
  1104         return dict(loss=total/N, loss_seg=seg_tot/N, loss_cls=cls_tot/N,
  1105                     loss_fused=fused_tot/N, accuracy=met["accuracy"],
  1106                     roc_auc=met["roc_auc"], kappa=met["quadratic_kappa"], ece=ece)
  1107
  1108     def fit(self) -> Dict[str, list]:
  1109         for epoch in range(1, self.epochs + 1):
  1110             t0 = time.time()
  1111             tr = self._run_epoch(self.train_dl, train=True)
  1112             va = self._run_epoch(self.val_dl,   train=False)
  1113             self.sched.step()
  1114
  1115             self.history["train_loss"].append(tr["loss"])
  1116             self.history["val_loss"].append(va["loss"])
  1117             self.history["val_auc"].append(va["roc_auc"])
  1118             self.history["val_kappa"].append(va["kappa"])
  1119
  1120             print(
  1121                 f"Epoch {epoch:03d}/{self.epochs}  "
  1122                 f"loss tr={tr['loss']:.4f} va={va['loss']:.4f}  "
  1123                 f"acc={va['accuracy']:.4f}  AUC={va['roc_auc']:.4f}  "
  1124                 f"κ={va['kappa']:.4f}  ECE={va['ece']:.4f}  "
  1125                 f"[{time.time()-t0:.1f}s]"
  1126             )
  1127
  1128             if va["loss"] < self.best_val_loss:
  1129                 self.best_val_loss     = va["loss"]
  1130                 self.epochs_no_improve = 0
  1131                 torch.save(dict(epoch=epoch, model=self.model.state_dict(),
  1132                                 ema=self.ema.model.state_dict(),
  1133                                 optimizer=self.opt.state_dict(),
  1134                                 metrics=va), self.ckpt)
  1135                 print(f"  ✓ checkpoint saved  (val_loss={va['loss']:.4f})")
  1136             else:
  1137                 self.epochs_no_improve += 1
  1138                 if self.epochs_no_improve >= self.patience:
  1139                     print(f"  Early stopping at epoch {epoch}.")
  1140                     break
  1141
  1142         ckpt = torch.load(self.ckpt, map_location=self.device)
  1143         self.model.load_state_dict(ckpt["model"])
  1144         print(f"\nTraining complete.  Best val loss: {self.best_val_loss:.4f}")
  1145         return self.history
