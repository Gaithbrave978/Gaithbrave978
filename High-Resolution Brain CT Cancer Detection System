   503 class CancerClassifier3D(nn.Module):
   504     """
   505     3-D EfficientNet-style patch classifier.
   506
   507     Input  : (B, in_channels, D, H, W)
   508     Output : (B, n_classes)
   509
   510     Classes
   511     -------
   512     0  No finding / benign
   513     1  Low-grade glioma
   514     2  High-grade glioma / GBM
   515     3  Brain metastasis
   516     4  Meningioma
   517     """
   518
   519     def __init__(
   520         self,
   521         in_channels: int = 5,
   522         n_classes: int = 5,
   523         dropout: float = 0.3,
   524     ):
   525         super().__init__()
   526         self.stem = ConvBnRelu(in_channels, 32, 3, stride=2)
   527         self.stages = nn.Sequential(
   528             MBConv3D(32,  16,  expand=1),
   529             MBConv3D(16,  24,  stride=2),
   530             MBConv3D(24,  24),
   531             MBConv3D(24,  40,  stride=2, kernel=5),
   532             MBConv3D(40,  40,  kernel=5),
   533             MBConv3D(40,  80,  stride=2),
   534             MBConv3D(80,  80),
   535             MBConv3D(80,  80),
   536             MBConv3D(80,  112, kernel=5),
   537             MBConv3D(112, 112, kernel=5),
   538             MBConv3D(112, 112, kernel=5),
   539             MBConv3D(112, 192, stride=2, kernel=5),
   540             MBConv3D(192, 192, kernel=5),
   541             MBConv3D(192, 192, kernel=5),
   542             MBConv3D(192, 192, kernel=5),
   543             MBConv3D(192, 320),
   544         )
   545         self.head = nn.Sequential(
   546             ConvBnRelu(320, 1280, 1),
   547             nn.AdaptiveAvgPool3d(1),
   548             nn.Flatten(),
   549             nn.Dropout(dropout),
   550             nn.Linear(1280, n_classes),
   551         )
   552         self._init_weights()
   553
   554     def _init_weights(self):
   555         for m in self.modules():
   556             if isinstance(m, nn.Conv3d):
   557                 nn.init.kaiming_normal_(m.weight)
   558             elif isinstance(m, nn.Linear):
   559                 nn.init.trunc_normal_(m.weight, std=0.02)
   560                 if m.bias is not None:
   561                     nn.init.zeros_(m.bias)
   562
   563     def forward(self, x: torch.Tensor) -> torch.Tensor:
   564         return self.head(self.stages(self.stem(x)))
