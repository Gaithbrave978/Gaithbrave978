  1152 class BrainCTScanner:
  1153     """
  1154     End-to-end inference for a single brain CT volume.
  1155
  1156     Steps
  1157     -----
  1158     1. Multi-channel HU windowing
  1159     2. Sliding-window 3-D segmentation (overlap-tile)
  1160     3. TTA × tta_n classification
  1161     4. MC-Dropout × mc_dropout_n uncertainty estimation
  1162     5. 3-D Grad-CAM heatmaps
  1163     6. Structured clinical report
  1164
  1165     Parameters
  1166     ----------
  1167     model_path   : path to a saved BrainCTEnsemble checkpoint
  1168     device       : 'cuda' or 'cpu'
  1169     patch_size   : cubic patch size for sliding window
  1170     stride       : window stride (use stride < patch_size for overlap)
  1171     tta_n        : test-time augmentation passes
  1172     mc_dropout_n : MC-Dropout samples (0 = disabled)
  1173     """
  1174
  1175     def __init__(
  1176         self,
  1177         model_path: str,
  1178         device: str = "cuda",
  1179         patch_size: int = 64,
  1180         stride: int = 32,
  1181         tta_n: int = 8,
  1182         mc_dropout_n: int = 20,
  1183     ):
  1184         self.device     = torch.device(
  1185             device if torch.cuda.is_available() else "cpu")
  1186         self.patch_size = patch_size
  1187         self.stride     = stride
  1188         self.tta_n      = tta_n
  1189         self.mc_n       = mc_dropout_n
  1190         self.augmentor  = CTAugmentor(p=1.0)
  1191
  1192         self.model = BrainCTEnsemble(in_ch=5, seg_classes=3, cls_classes=5)
  1193         ckpt  = torch.load(model_path, map_location=self.device)
  1194         state = ckpt.get("ema", ckpt.get("model", ckpt))
  1195         self.model.load_state_dict(state)
  1196         self.model.to(self.device).eval()
  1197
  1198         self.gcam     = GradCAM3D(self.model,
  1199                                    self.model.classifier.stages[-1])
  1200         self.seg_gcam = SegGradCAM3D(self.model,
  1201                                       self.model.segmentor.dec1)
  1202
  1203     @torch.no_grad()
  1204     def _segment_volume(self, vol5: np.ndarray) -> np.ndarray:
  1205         D, H, W   = vol5.shape[1:]
  1206         seg_sum   = np.zeros((3, D, H, W), dtype=np.float32)
  1207         count_map = np.zeros((D, H, W),    dtype=np.float32)
  1208
  1209         patches, coords = extract_patches_3d(vol5, self.patch_size, self.stride)
  1210         for patch, (d1, h1, w1, d2, h2, w2) in zip(patches, coords):
  1211             t = torch.from_numpy(patch).unsqueeze(0).to(self.device)
  1212             prob = torch.softmax(self.model(t)[0], 1).squeeze(0).cpu().numpy()
  1213             pd, ph, pw = d2 - d1, h2 - h1, w2 - w1
  1214             seg_sum[:, d1:d2, h1:h2, w1:w2] += prob[:, :pd, :ph, :pw]
  1215             count_map[   d1:d2, h1:h2, w1:w2] += 1.0
  1216
  1217         return seg_sum / np.maximum(count_map[None], 1)
  1218
  1219     def _classify_tta(self, x: torch.Tensor) -> np.ndarray:
  1220         dummy = torch.zeros(x.size(0), 3, *x.shape[2:], device=self.device)
  1221         probs = []
  1222         for _ in range(self.tta_n):
  1223             aug, _ = self.augmentor(x.clone(), torch.zeros_like(x[:, :1]))
  1224             inp    = torch.cat([aug, dummy], dim=1)
  1225             with torch.no_grad():
  1226                 probs.append(
  1227                     torch.softmax(self.model.classifier(inp), 1).cpu().numpy())
  1228         return np.stack(probs).mean(0)
  1229
  1230     def _mc_uncertainty(
  1231         self,
  1232         x: torch.Tensor,
  1233     ) -> Tuple[Optional[np.ndarray], Optional[np.ndarray]]:
  1234         if self.mc_n == 0:
  1235             return None, None
  1236
  1237         dummy = torch.zeros(x.size(0), 3, *x.shape[2:], device=self.device)
  1238         inp   = torch.cat([x, dummy], dim=1)
  1239
  1240         def _enable_dropout(m):
  1241             if isinstance(m, (nn.Dropout, nn.Dropout3d)):
  1242                 m.train()
  1243
  1244         self.model.apply(_enable_dropout)
  1245         samples = []
  1246         with torch.no_grad():
  1247             for _ in range(self.mc_n):
  1248                 samples.append(
  1249                     torch.softmax(self.model.classifier(inp), 1).cpu().numpy())
  1250         self.model.eval()
  1251         samples = np.stack(samples)
  1252         return samples.mean(0), samples.var(0).sum(-1)
  1253
  1254     def scan(
  1255         self,
  1256         hu_volume: np.ndarray,
  1257         voxel_spacing: Tuple[float, ...] = (1., 1., 1.),
  1258     ) -> Dict:
  1259         """
  1260         Run the full diagnostic pipeline on one CT volume.
  1261
  1262         Parameters
  1263         ----------
  1264         hu_volume     : (D, H, W) Hounsfield Unit array
  1265         voxel_spacing : (dx, dy, dz) in millimetres
  1266
  1267         Returns
  1268         -------
  1269         {
  1270           seg_mask    : (D, H, W) uint8  — 0/1/2 class labels
  1271           seg_probs   : (3, D, H, W)     — soft probabilities
  1272           cls_probs   : (5,)             — diagnosis probabilities
  1273           cls_label   : str              — top diagnosis
  1274           confidence  : float            — top-class probability
  1275           uncertainty : float            — MC-Dropout variance
  1276           gradcam_cls : (D, H, W)        — classification saliency map
  1277           gradcam_seg : (D, H, W)        — segmentation saliency map
  1278           report      : str              — formatted clinical report
  1279         }
  1280         """
  1281         print("[1/5] Multi-channel HU windowing …")
  1282         vol5 = multi_channel_window(hu_volume)
  1283
  1284         print("[2/5] Sliding-window segmentation …")
  1285         seg_probs = self._segment_volume(vol5)
  1286         seg_mask  = seg_probs.argmax(0).astype(np.uint8)
  1287
  1288         print("[3/5] TTA classification …")
  1289         x    = torch.from_numpy(vol5).unsqueeze(0).to(self.device)
  1290         tta  = self._classify_tta(x)
  1291         mc_p, unc = self._mc_uncertainty(x)
  1292         cls_probs  = (0.6 * tta + 0.4 * mc_p) if mc_p is not None else tta
  1293         uncertainty = float(unc[0]) if unc is not None else 0.0
  1294
  1295         cls_idx    = int(cls_probs.argmax(1)[0])
  1296         confidence = float(cls_probs[0, cls_idx])
  1297
  1298         print("[4/5] Generating Grad-CAM heatmaps …")
  1299         gradcam_cls = self.gcam(x, class_idx=cls_idx)
  1300         gradcam_seg = self.seg_gcam(x, seg_class=2)
  1301
  1302         print("[5/5] Generating report …")
  1303         vv             = float(np.prod(voxel_spacing)) / 1000.0
  1304         tumour_vol_cm3 = float((seg_mask == 2).sum()) * vv
  1305         report         = _format_report(cls_idx, confidence, uncertainty,
  1306                                         cls_probs[0], tumour_vol_cm3, seg_probs)
  1307
  1308         return dict(seg_mask=seg_mask, seg_probs=seg_probs,
  1309                     cls_probs=cls_probs[0], cls_label=CLS_NAMES[cls_idx],
  1310                     confidence=confidence, uncertainty=uncertainty,
  1311                     gradcam_cls=gradcam_cls, gradcam_seg=gradcam_seg,
  1312                     report=report)
  1313
  1314
  1315 def _format_report(
  1316     cls_idx: int,
  1317     confidence: float,
  1318     uncertainty: float,
  1319     probs: np.ndarray,
  1320     tumour_vol: float,
  1321     seg_probs: np.ndarray,
  1322 ) -> str:
  1323     risk = ("CRITICAL" if cls_idx in (2, 3) and confidence > 0.70 else
  1324             "HIGH"     if cls_idx in (1, 2, 3)                     else
  1325             "LOW")
  1326     oedema_vol = float((seg_probs.argmax(0) == 1).sum()) * 0.001
  1327     lines = [
  1328         "=" * 65,
  1329         "  Gaith Krakdia Brain CT Scan model 1.0",
  1330         "  CANCER DETECTION REPORT",
  1331         "=" * 65,
  1332         f"  Diagnosis     : {CLS_NAMES[cls_idx]}",
  1333         f"  Risk Level    : {risk}",
  1334         f"  Confidence    : {confidence * 100:.1f}%",
  1335         f"  Uncertainty   : {uncertainty:.4f}  (MC-Dropout epistemic)",
  1336         "",
  1337         "  Class Probabilities:",
  1338     ]
  1339     for name, p in zip(CLS_NAMES, probs):
  1340         bar = chr(9608) * int(p * 30)
  1341         lines.append(f"    {name:<34s}  {p * 100:5.1f}%  {bar}")
  1342     lines += [
  1343         "",
  1344         "  Segmentation Volumes:",
  1345         f"    Oedema zone          : {oedema_vol:.2f} cm3",
  1346         f"    Enhancing tumour     : {tumour_vol:.2f} cm3",
  1347         "",
  1348         "  WARNING: AI output is for research / decision-support only.",
  1349         "           All findings MUST be reviewed by a qualified radiologist.",
  1350         "=" * 65,
  1351     ]
  1352     return "\n".join(lines)
