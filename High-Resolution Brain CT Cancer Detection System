#  SECTION 4 — 3D EfficientNet-style CLASSIFIER
# ══════════════════════════════════════════════════════════════════════════════

class MBConv3D(nn.Module):
    """Mobile inverted bottleneck with 3-D depthwise convolution + SE."""

    def __init__(
        self,
        in_ch: int,
        out_ch: int,
        expand: int = 6,
        kernel: int = 3,
        stride: int = 1,
        se_ratio: int = 4,
    ):
        super().__init__()
        mid         = in_ch * expand
        self.expand = ConvBnRelu(in_ch, mid, 1) if expand != 1 else nn.Identity()
        self.dw     = ConvBnRelu(mid, mid, kernel, stride=stride, groups=mid)
        self.se     = SEBlock3D(mid, se_ratio)
        self.proj   = nn.Sequential(
            nn.Conv3d(mid, out_ch, 1, bias=False),
            nn.InstanceNorm3d(out_ch, affine=True),
        )
        self.skip = stride == 1 and in_ch == out_ch

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        h = self.proj(self.se(self.dw(self.expand(x))))
        return x + h if self.skip else h


class CancerClassifier3D(nn.Module):
    """
    3-D EfficientNet-style patch classifier.

    Input  : (B, in_channels, D, H, W)
    Output : (B, n_classes)

    Classes
    -------
    0  No finding / benign
    1  Low-grade glioma
    2  High-grade glioma / GBM
    3  Brain metastasis
    4  Meningioma
    """

    def __init__(
        self,
        in_channels: int = 5,
        n_classes: int = 5,
        dropout: float = 0.3,
    ):
        super().__init__()
        self.stem = ConvBnRelu(in_channels, 32, 3, stride=2)
        self.stages = nn.Sequential(
            MBConv3D(32,  16,  expand=1),
            MBConv3D(16,  24,  stride=2),
            MBConv3D(24,  24),
            MBConv3D(24,  40,  stride=2, kernel=5),
            MBConv3D(40,  40,  kernel=5),
            MBConv3D(40,  80,  stride=2),
            MBConv3D(80,  80),
            MBConv3D(80,  80),
            MBConv3D(80,  112, kernel=5),
            MBConv3D(112, 112, kernel=5),
            MBConv3D(112, 112, kernel=5),
            MBConv3D(112, 192, stride=2, kernel=5),
            MBConv3D(192, 192, kernel=5),
            MBConv3D(192, 192, kernel=5),
            MBConv3D(192, 192, kernel=5),
            MBConv3D(192, 320),
        )
        self.head = nn.Sequential(
            ConvBnRelu(320, 1280, 1),
            nn.AdaptiveAvgPool3d(1),
            nn.Flatten(),
            nn.Dropout(dropout),
            nn.Linear(1280, n_classes),
        )
        self._init_weights()

    def _init_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Conv3d):
                nn.init.kaiming_normal_(m.weight)
            elif isinstance(m, nn.Linear):
                nn.init.trunc_normal_(m.weight, std=0.02)
                if m.bias is not None:
                    nn.init.zeros_(m.bias)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.head(self.stages(self.stem(x)))


