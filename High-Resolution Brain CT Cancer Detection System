  1370 def _overlay_seg(ct: np.ndarray, seg: np.ndarray, alpha=0.4) -> np.ndarray:
  1371     rgb = cv2.cvtColor(ct, cv2.COLOR_GRAY2RGB).astype(float)
  1372     for c in range(1, 3):
  1373         mask  = (seg == c)
  1374         color = _SEG_COLORS[c] * 255
  1375         for ch in range(3):
  1376             rgb[..., ch] = np.where(mask,
  1377                                      rgb[..., ch] * (1 - alpha) + color[ch] * alpha,
  1378                                      rgb[..., ch])
  1379     return np.clip(rgb, 0, 255).astype(np.uint8)
  1380
  1381
  1382 def _overlay_cam(ct: np.ndarray, cam: np.ndarray, alpha=0.5) -> np.ndarray:
  1383     jet = cv2.applyColorMap((cam * 255).astype(np.uint8), cv2.COLORMAP_JET)
  1384     rgb = cv2.cvtColor(ct, cv2.COLOR_GRAY2RGB)
  1385     return cv2.addWeighted(rgb, 1 - alpha, jet, alpha, 0)
