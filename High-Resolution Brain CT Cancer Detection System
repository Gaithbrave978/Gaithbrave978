  1490 def _make_synthetic_ct(shape=(64, 128, 128), seed=42) -> np.ndarray:
  1491     """Generate a synthetic HU volume with an embedded GBM-like lesion."""
  1492     rng = np.random.default_rng(seed)
  1493     vol = rng.normal(-10, 15, shape).astype(np.float32)
  1494     D, H, W = shape
  1495     z, y, x = np.ogrid[:D, :H, :W]
  1496
  1497     brain = ((z-D//2)**2/(D//3)**2 + (y-H//2)**2/(H//2.5)**2 +
  1498              (x-W//2)**2/(W//2.5)**2) < 1
  1499     vol[brain] = rng.normal(35, 8, int(brain.sum()))
  1500
  1501     lesion = ((z-D//2-4)**2/8**2 + (y-H//2-6)**2/12**2 +
  1502               (x-W//2+8)**2/12**2) < 1
  1503     vol[lesion] = rng.normal(55, 12, int(lesion.sum()))
  1504
  1505     necrosis = ((z-D//2-5)**2/4**2 + (y-H//2-5)**2/5**2 +
  1506                 (x-W//2+9)**2/5**2) < 1
  1507     vol[necrosis] = rng.normal(-20, 5, int(necrosis.sum()))
  1508
  1509     return vol
