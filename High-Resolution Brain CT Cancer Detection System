   571 class BrainCTEnsemble(nn.Module):
   572     """
   573     Full diagnostic pipeline in a single nn.Module:
   574
   575       AttentionUNet3D  ──► seg logits (B, 3, D, H, W)
   576                                 │
   577       CancerClassifier3D ◄──────┤  (CT + seg probs concatenated)
   578                                 │
   579       MetaFusion MLP   ──► final diagnosis (B, 5)
   580
   581     Parameters
   582     ----------
   583     in_ch       : input CT channels (5 for multi-window)
   584     seg_classes : segmentation classes (default 3)
   585     cls_classes : diagnosis classes   (default 5)
   586     base_ch     : U-Net base channels (32 for production, 8 for unit tests)
   587     """
   588
   589     def __init__(
   590         self,
   591         in_ch: int = 5,
   592         seg_classes: int = 3,
   593         cls_classes: int = 5,
   594         base_ch: int = 32,
   595     ):
   596         super().__init__()
   597         self.segmentor  = AttentionUNet3D(in_ch, seg_classes, base_ch)
   598         self.classifier = CancerClassifier3D(in_ch + seg_classes, cls_classes)
   599         self.fusion     = nn.Sequential(
   600             nn.Linear(cls_classes + seg_classes, 128),
   601             nn.GELU(),
   602             nn.Dropout(0.2),
   603             nn.Linear(128, cls_classes),
   604         )
   605
   606     def forward(
   607         self,
   608         x: torch.Tensor,
   609     ) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
   610         """
   611         Returns
   612         -------
   613         seg_logits : (B, seg_classes, D, H, W)
   614         cls_logits : (B, cls_classes)
   615         fused      : (B, cls_classes)  ← use this for final diagnosis
   616         """
   617         seg_logits  = self.segmentor(x)
   618         seg_probs   = torch.softmax(seg_logits, dim=1)
   619         cls_input   = torch.cat([x, seg_probs], dim=1)
   620         cls_logits  = self.classifier(cls_input)
   621         seg_summary = seg_probs.mean(dim=[2, 3, 4])
   622         fused       = self.fusion(torch.cat([cls_logits, seg_summary], dim=1))
   623         return seg_logits, cls_logits, fused
   624
   625
