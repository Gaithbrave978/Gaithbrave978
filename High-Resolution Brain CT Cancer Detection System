class BrainCTScanner:
    """
    End-to-end inference for a single brain CT volume.

    Steps
    -----
    1. Multi-channel HU windowing
    2. Sliding-window 3-D segmentation (overlap-tile)
    3. TTA × tta_n classification
    4. MC-Dropout × mc_dropout_n uncertainty estimation
    5. 3-D Grad-CAM heatmaps
    6. Structured clinical report

    Parameters
    ----------
    model_path   : path to a saved BrainCTEnsemble checkpoint
    device       : 'cuda' or 'cpu'
    patch_size   : cubic patch size for sliding window
    stride       : window stride (use stride < patch_size for overlap)
    tta_n        : test-time augmentation passes
    mc_dropout_n : MC-Dropout samples (0 = disabled)
    """

    def __init__(
        self,
        model_path: str,
        device: str = "cuda",
        patch_size: int = 64,
        stride: int = 32,
        tta_n: int = 8,
        mc_dropout_n: int = 20,
    ):
        self.device     = torch.device(
            device if torch.cuda.is_available() else "cpu")
        self.patch_size = patch_size
        self.stride     = stride
        self.tta_n      = tta_n
        self.mc_n       = mc_dropout_n
        self.augmentor  = CTAugmentor(p=1.0)

        self.model = BrainCTEnsemble(in_ch=5, seg_classes=3, cls_classes=5)
        ckpt  = torch.load(model_path, map_location=self.device)
        state = ckpt.get("ema", ckpt.get("model", ckpt))
        self.model.load_state_dict(state)
        self.model.to(self.device).eval()

        self.gcam      = GradCAM3D(self.model, 
                                   self.model.classifier.stages[-1])
        self.seg_gcam = SegGradCAM3D(self.model,
                                      self.model.segmentor.dec1)

    @torch.no_grad()
    def _segment_volume(self, vol5: np.ndarray) -> np.ndarray:
        D, H, W   = vol5.shape[1:]
        seg_sum   = np.zeros((3, D, H, W), dtype=np.float32)
        count_map = np.zeros((D, H, W),    dtype=np.float32)

        patches, coords = extract_patches_3d(vol5, self.patch_size, self.stride)
        for patch, (d1, h1, w1, d2, h2, w2) in zip(patches, coords):
            t = torch.from_numpy(patch).unsqueeze(0).to(self.device)
            prob = torch.softmax(self.model(t)[0], 1).squeeze(0).cpu().numpy()
            pd, ph, pw = d2 - d1, h2 - h1, w2 - w1
            seg_sum[:, d1:d2, h1:h2, w1:w2] += prob[:, :pd, :ph, :pw]
            count_map[   d1:d2, h1:h2, w1:w2] += 1.0

        return seg_sum / np.maximum(count_map[None], 1)

    def _classify_tta(self, x: torch.Tensor) -> np.ndarray:
        dummy = torch.zeros(x.size(0), 3, *x.shape[2:], device=self.device)
        probs = []
        for _ in range(self.tta_n):
            aug, _ = self.augmentor(x.clone(), torch.zeros_like(x[:, :1]))
            inp    = torch.cat([aug, dummy], dim=1)
            with torch.no_grad():
                probs.append(
                    torch.softmax(self.model.classifier(inp), 1).cpu().numpy())
        return np.stack(probs).mean(0)

    def _mc_uncertainty(
        self,
        x: torch.Tensor,
    ) -> Tuple[Optional[np.ndarray], Optional[np.ndarray]]:
        if self.mc_n == 0:
            return None, None

        dummy = torch.zeros(x.size(0), 3, *x.shape[2:], device=self.device)
        inp   = torch.cat([x, dummy], dim=1)

        def _enable_dropout(m):
            if isinstance(m, (nn.Dropout, nn.Dropout3d)):
                m.train()

        self.model.apply(_enable_dropout)
        samples = []
        with torch.no_grad():
            for _ in range(self.mc_n):
                samples.append(
                    torch.softmax(self.model.classifier(inp), 1).cpu().numpy())
        self.model.eval()
        samples = np.stack(samples)
        return samples.mean(0), samples.var(0).sum(-1)

    def scan(
        self,
        hu_volume: np.ndarray,
        voxel_spacing: Tuple[float, ...] = (1., 1., 1.),
    ) -> Dict:
        """
        Run the full diagnostic pipeline on one CT volume.

        Parameters
        ----------
        hu_volume     : (D, H, W) Hounsfield Unit array
        voxel_spacing : (dx, dy, dz) in millimetres

        Returns
        -------
        {
           seg_mask    : (D, H, W) uint8  — 0/1/2 class labels
           seg_probs   : (3, D, H, W)     — soft probabilities
           cls_probs   : (5,)             — diagnosis probabilities
           cls_label   : str              — top diagnosis
           confidence  : float            — top-class probability
           uncertainty : float            — MC-Dropout variance
           gradcam_cls : (D, H, W)        — classification saliency map
           gradcam_seg : (D, H, W)        — segmentation saliency map
           report      : str              — formatted clinical report
        }
        """
        print("[1/5] Multi-channel HU windowing …")
        vol5 = multi_channel_window(hu_volume)

        print("[2/5] Sliding-window segmentation …")
        seg_probs = self._segment_volume(vol5)
        seg_mask  = seg_probs.argmax(0).astype(np.uint8)

        print("[3/5] TTA classification …")
        x    = torch.from_numpy(vol5).unsqueeze(0).to(self.device)
        tta  = self._classify_tta(x)
        mc_p, unc = self._mc_uncertainty(x)
        cls_probs  = (0.6 * tta + 0.4 * mc_p) if mc_p is not None else tta
        uncertainty = float(unc[0]) if unc is not None else 0.0

        cls_idx    = int(cls_probs.argmax(1)[0])
        confidence = float(cls_probs[0, cls_idx])

        print("[4/5] Generating Grad-CAM heatmaps …")
        gradcam_cls = self.gcam(x, class_idx=cls_idx)
        gradcam_seg = self.seg_gcam(x, seg_class=2)

        print("[5/5] Generating report …")
        vv             = float(np.prod(voxel_spacing)) / 1000.0
        tumour_vol_cm3 = float((seg_mask == 2).sum()) * vv
        report         = _format_report(cls_idx, confidence, uncertainty,
                                        cls_probs[0], tumour_vol_cm3, seg_probs)

        return dict(seg_mask=seg_mask, seg_probs=seg_probs,
                    cls_probs=cls_probs[0], cls_label=CLS_NAMES[cls_idx],
                    confidence=confidence, uncertainty=uncertainty,
                    gradcam_cls=gradcam_cls, gradcam_seg=gradcam_seg,
                    report=report)


def _format_report(
    cls_idx: int,
    confidence: float,
    uncertainty: float,
    probs: np.ndarray,
    tumour_vol: float,
    seg_probs: np.ndarray,
) -> str:
    risk = ("CRITICAL" if cls_idx in (2, 3) and confidence > 0.70 else
            "HIGH"     if cls_idx in (1, 2, 3)                     else
            "LOW")
    oedema_vol = float((seg_probs.argmax(0) == 1).sum()) * 0.001
    lines = [
        "=" * 65,
        "  Gaith Krakdia Brain CT Scan model 1.0",
        "  CANCER DETECTION REPORT",
        "=" * 65,
        f"  Diagnosis     : {CLS_NAMES[cls_idx]}",
        f"  Risk Level    : {risk}",
        f"  Confidence    : {confidence * 100:.1f}%",
        f"  Uncertainty   : {uncertainty:.4f}  (MC-Dropout epistemic)",
        "",
        "  Class Probabilities:",
    ]
    for name, p in zip(CLS_NAMES, probs):
        bar = chr(9608) * int(p * 30)
        lines.append(f"    {name:<34s}  {p * 100:5.1f}%  {bar}")
    lines += [
        "",
        "  Segmentation Volumes:",
        f"    Oedema zone          : {oedema_vol:.2f} cm3",
        f"    Enhancing tumour     : {tumour_vol:.2f} cm3",
        "",
        "  WARNING: AI output is for research / decision-support only.",
        "           All findings MUST be reviewed by a qualified radiologist.",
        "=" * 65,
    ]
    return "\n".join(lines)


