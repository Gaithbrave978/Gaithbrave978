class GradCAM3D:
    """
    Gradient-weighted Class Activation Mapping for 3-D CNNs.

    Usage
    -----
    gcam    = GradCAM3D(model, target_layer=model.classifier.stages[-1])
    heatmap = gcam(input_tensor, class_idx=2)   # 2 = High-Grade GBM
    heatmap shape: (D, H, W), values in [0, 1]
    """

    def __init__(self, model: nn.Module, target_layer: nn.Module):
        self.model        = model
        self.target_layer = target_layer
        self._gradients: Optional[torch.Tensor] = None
        self._activations: Optional[torch.Tensor] = None
        target_layer.register_forward_hook(
            lambda _, __, o: setattr(self, "_activations", o.detach()))
        target_layer.register_full_backward_hook(
            lambda _, __, g: setattr(self, "_gradients", g[0].detach()))

    @torch.enable_grad()
    def __call__(
        self,
        x: torch.Tensor,
        class_idx: Optional[int] = None,
    ) -> np.ndarray:
        self.model.eval()
        x = x.requires_grad_(True)
        logits = self.model(x)
        if isinstance(logits, tuple):
            logits = logits[2]
        if class_idx is None:
            class_idx = int(logits.argmax(dim=1).item())
        self.model.zero_grad()
        logits[0, class_idx].backward()
        weights = self._gradients.mean(dim=[2, 3, 4], keepdim=True)
        cam     = F.relu((weights * self._activations).sum(1, keepdim=True))
        cam     = F.interpolate(cam, size=x.shape[2:],
                                mode="trilinear", align_corners=False)
        cam     = cam.squeeze().cpu().numpy()
        cam_max = cam.max()
        return cam / (cam_max + 1e-8)


class SegGradCAM3D:
    """Grad-CAM adapted for the segmentation head."""

    def __init__(self, model: nn.Module, target_layer: nn.Module):
        self.model        = model
        self.target_layer = target_layer
        self._gradients: Optional[torch.Tensor] = None
        self._activations: Optional[torch.Tensor] = None
        target_layer.register_forward_hook(
            lambda _, __, o: setattr(self, "_activations", o.detach()))
        target_layer.register_full_backward_hook(
            lambda _, __, g: setattr(self, "_gradients", g[0].detach()))

    @torch.enable_grad()
    def __call__(
        self,
        x: torch.Tensor,
        seg_class: int = 2,
    ) -> np.ndarray:
        self.model.eval()
        x          = x.requires_grad_(True)
        seg_log, *_ = self.model(x)
        self.model.zero_grad()
        seg_log[:, seg_class].mean().backward()
        weights = self._gradients.mean(dim=[2, 3, 4], keepdim=True)
        cam     = F.relu((weights * self._activations).sum(1, keepdim=True))
        cam     = F.interpolate(cam, size=x.shape[2:],
                                mode="trilinear", align_corners=False)
        cam     = cam.squeeze().cpu().numpy()
        return cam / (cam.max() + 1e-8)


