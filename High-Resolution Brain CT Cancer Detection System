def _make_synthetic_ct(shape=(64, 128, 128), seed=42) -> np.ndarray:
    """Generate a synthetic HU volume with an embedded GBM-like lesion."""
    rng = np.random.default_rng(seed)
    vol = rng.normal(-10, 15, shape).astype(np.float32)
    D, H, W = shape
    z, y, x = np.ogrid[:D, :H, :W]

    brain = ((z-D//2)**2/(D//3)**2 + (y-H//2)**2/(H//2.5)**2 + 
             (x-W//2)**2/(W//2.5)**2) < 1
    vol[brain] = rng.normal(35, 8, int(brain.sum()))

    lesion = ((z-D//2-4)**2/8**2 + (y-H//2-6)**2/12**2 + 
               (x-W//2+8)**2/12**2) < 1
    vol[lesion] = rng.normal(55, 12, int(lesion.sum()))

    necrosis = ((z-D//2-5)**2/4**2 + (y-H//2-5)**2/5**2 + 
                 (x-W//2+9)**2/5**2) < 1
    vol[necrosis] = rng.normal(-20, 5, int(necrosis.sum()))

    return vol


