_SEG_COLORS = np.array([
    [0,   0,   0  ],
    [0,   255, 255],
    [255, 50,  50 ],
], dtype=np.float32) / 255.0


def _hu_to_uint8(vol: np.ndarray, wmin=-20, wmax=80) -> np.ndarray:
    return ((np.clip(vol, wmin, wmax) - wmin) / (wmax - wmin) * 255).astype(np.uint8)


def _overlay_seg(ct: np.ndarray, seg: np.ndarray, alpha=0.4) -> np.ndarray:
    rgb = cv2.cvtColor(ct, cv2.COLOR_GRAY2RGB).astype(float)
    for c in range(1, 3):
        mask  = (seg == c)
        color = _SEG_COLORS[c] * 255
        for ch in range(3):
            rgb[..., ch] = np.where(mask,
                                    rgb[..., ch] * (1 - alpha) + color[ch] * alpha,
                                    rgb[..., ch])
    return np.clip(rgb, 0, 255).astype(np.uint8)


def _overlay_cam(ct: np.ndarray, cam: np.ndarray, alpha=0.5) -> np.ndarray:
    jet = cv2.applyColorMap((cam * 255).astype(np.uint8), cv2.COLORMAP_JET)
    rgb = cv2.cvtColor(ct, cv2.COLOR_GRAY2RGB)
    return cv2.addWeighted(rgb, 1 - alpha, jet, alpha, 0)


def plot_scan(
    hu_volume: np.ndarray,
    seg_mask: Optional[np.ndarray] = None,
    gradcam: Optional[np.ndarray] = None,
    n_slices: int = 6,
    title: str = "Gaith Krakdia Brain CT Scan model 1.0",
    save_path: Optional[str] = None,
):
    """
    Multi-slice visualisation:
      Row 1 — raw CT (brain window)
      Row 2 — segmentation overlay    (if seg_mask provided)
      Row 3 — Grad-CAM overlay        (if gradcam provided)
    """
    idxs   = np.linspace(0, hu_volume.shape[0] - 1, n_slices, dtype=int)
    n_rows = 1 + (seg_mask is not None) + (gradcam is not None)
    fig, axes = plt.subplots(n_rows, n_slices, 
                             figsize=(n_slices * 3, n_rows * 3))
    if n_rows == 1:
        axes = axes[np.newaxis, :]

    fig.suptitle(title, fontsize=14, fontweight="bold")
    for col, idx in enumerate(idxs):
        ct = _hu_to_uint8(hu_volume[idx])
        axes[0, col].imshow(ct, cmap="gray", vmin=0, vmax=255)
        axes[0, col].set_title(f"z={idx}", fontsize=9)
        axes[0, col].axis("off")
        r = 1
        if seg_mask is not None:
            axes[r, col].imshow(_overlay_seg(ct, seg_mask[idx]))
            axes[r, col].axis("off")
            r += 1
        if gradcam is not None:
            axes[r, col].imshow(_overlay_cam(ct, gradcam[idx]))
            axes[r, col].axis("off")

    row_labels = ["CT (brain window)"]
    if seg_mask is not None: row_labels.append("Segmentation")
    if gradcam  is not None: row_labels.append("Grad-CAM")
    for row, label in enumerate(row_labels):
        axes[row, 0].set_ylabel(label, fontsize=10)

    plt.tight_layout()
    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches="tight")
        print(f"Saved: {save_path}")
    else:
        plt.show()


