   348 class TransformerBottleneck(nn.Module):
   349     """
   350     Lightweight ViT-style multi-head self-attention at the U-Net bottleneck.
   351     Captures long-range spatial dependencies across the full volume.
   352     """
   353
   354     def __init__(self, ch: int, heads: int = 8, dropout: float = 0.1):
   355         super().__init__()
   356         self.norm1 = nn.LayerNorm(ch)
   357         self.attn  = nn.MultiheadAttention(ch, heads,
   358                                             dropout=dropout, batch_first=True)
   359         self.norm2 = nn.LayerNorm(ch)
   360         self.ff = nn.Sequential(
   361             nn.Linear(ch, ch * 4), nn.GELU(),
   362             nn.Dropout(dropout),
   363             nn.Linear(ch * 4, ch), nn.Dropout(dropout),
   364         )
   365
   366     def forward(self, x: torch.Tensor) -> torch.Tensor:
   367         B, C, D, H, W = x.shape
   368         t = rearrange(x, "b c d h w -> b (d h w) c")
   369         t = t + self.attn(*([self.norm1(t)] * 3))[0]
   370         t = t + self.ff(self.norm2(t))
   371         return rearrange(t, "b (d h w) c -> b c d h w", d=D, h=H, w=W)
   372
