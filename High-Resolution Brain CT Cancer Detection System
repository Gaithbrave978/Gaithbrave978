   279 class ResidualBlock(nn.Module):
   280     """Pre-activation residual block with instance normalisation."""
   281
   282     def __init__(self, ch: int, dropout: float = 0.1):
   283         super().__init__()
   284         self.norm1  = nn.InstanceNorm3d(ch, affine=True)
   285         self.conv1  = nn.Conv3d(ch, ch, 3, padding=1, bias=False)
   286         self.norm2  = nn.InstanceNorm3d(ch, affine=True)
   287         self.drop   = nn.Dropout3d(dropout)
   288         self.conv2  = nn.Conv3d(ch, ch, 3, padding=1, bias=False)
   289         self.act    = nn.LeakyReLU(0.1, inplace=True)
   290
   291     def forward(self, x: torch.Tensor) -> torch.Tensor:
   292         h = self.conv1(self.act(self.norm1(x)))
   293         h = self.conv2(self.drop(self.act(self.norm2(h))))
   294         return x + h
   295
