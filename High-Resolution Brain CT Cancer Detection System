   475 class MBConv3D(nn.Module):
   476     """Mobile inverted bottleneck with 3-D depthwise convolution + SE."""
   477
   478     def __init__(
   479         self,
   480         in_ch: int,
   481         out_ch: int,
   482         expand: int = 6,
   483         kernel: int = 3,
   484         stride: int = 1,
   485         se_ratio: int = 4,
   486     ):
   487         super().__init__()
   488         mid         = in_ch * expand
   489         self.expand = ConvBnRelu(in_ch, mid, 1) if expand != 1 else nn.Identity()
   490         self.dw     = ConvBnRelu(mid, mid, kernel, stride=stride, groups=mid)
   491         self.se     = SEBlock3D(mid, se_ratio)
   492         self.proj   = nn.Sequential(
   493             nn.Conv3d(mid, out_ch, 1, bias=False),
   494             nn.InstanceNorm3d(out_ch, affine=True),
   495         )
   496         self.skip = stride == 1 and in_ch == out_ch
   497
   498     def forward(self, x: torch.Tensor) -> torch.Tensor:
   499         h = self.proj(self.se(self.dw(self.expand(x))))
   500         return x + h if self.skip else h
