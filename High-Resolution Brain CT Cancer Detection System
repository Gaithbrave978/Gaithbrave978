   167 def extract_patches_3d(
   168     volume: np.ndarray,
   169     patch_size: int = 64,
   170     stride: int = 32,
   171 ) -> Tuple[np.ndarray, List[Tuple]]:
   172     """
   173     Sliding-window 3-D patch extraction.
   174     Returns (patches array [N, C, D, H, W], list of (d1,h1,w1,d2,h2,w2)).
   175     """
   176     D, H, W = volume.shape[-3:]
   177     patches, coords = [], []
   178
   179     for d in range(0, max(1, D - patch_size + 1), stride):
   180         for h in range(0, max(1, H - patch_size + 1), stride):
   181             for w in range(0, max(1, W - patch_size + 1), stride):
   182                 d2 = min(d + patch_size, D)
   183                 h2 = min(h + patch_size, H)
   184                 w2 = min(w + patch_size, W)
   185                 patch = volume[..., d:d2, h:h2, w:w2]
   186                 pd = patch_size - patch.shape[-3]
   187                 ph = patch_size - patch.shape[-2]
   188                 pw = patch_size - patch.shape[-1]
   189                 if pd > 0 or ph > 0 or pw > 0:
   190                     patch = np.pad(
   191                         patch,
   192                         [(0, 0)] * (patch.ndim - 3) + [(0, pd), (0, ph), (0, pw)],
   193                     )
   194                 patches.append(patch)
   195                 coords.append((d, h, w, d2, h2, w2))
   196
   197     return np.stack(patches), coords
