HU_WINDOWS: Dict[str, Tuple[float, float]] = {
    "brain":        (-20,   80),
    "blood":        ( 50,  100),
    "bone":         (400, 1000),
    "tumor":        ( 20,   60),
    "white_matter": ( 20,   45),
}

CLS_NAMES = [
    "No Finding",
    "Low-Grade Glioma",
    "High-Grade Glioma / GBM",
    "Metastasis",
    "Meningioma",
]

SEG_NAMES = ["background", "oedema", "enhancing_tumour"]


def apply_hu_window(volume: np.ndarray, wmin: float, wmax: float) -> np.ndarray:
    """Clip HU values to [wmin, wmax] and scale linearly to [0, 1]."""
    return (np.clip(volume, wmin, wmax) - wmin) / (wmax - wmin)


def multi_channel_window(volume: np.ndarray) -> np.ndarray:
    """
    Produce a 5-channel float32 representation of a single HU volume.
    Each channel uses a clinically meaningful window — analogous to
    different MRI sequences in terms of tissue contrast.
    Output shape: (5, D, H, W)
    """
    channels = [
        apply_hu_window(volume, lo, hi)
        for lo, hi in HU_WINDOWS.values()
    ]
    return np.stack(channels, axis=0).astype(np.float32)


def strip_skull(
    volume: np.ndarray,
    hu_min: float = -20,
    hu_max: float = 80,
) -> Tuple[np.ndarray, np.ndarray]:
    """
    Morphology-based skull stripping.
    Returns (stripped_volume, binary_brain_mask).
    """
    mask = np.logical_and(volume >= hu_min, volume <= hu_max)
    mask = morphology.remove_small_objects(mask, min_size=5_000)

    filled = np.zeros_like(mask)
    for i in range(mask.shape[0]):
        filled[i] = ndimage.binary_fill_holes(mask[i])

    labeled = measure.label(filled)
    props   = measure.regionprops(labeled)
    if props:
        largest = max(props, key=lambda p: p.area)
        mask = (labeled == largest.label)
    else:
        mask = filled

    stripped = volume.copy().astype(np.float32)
    stripped[~mask] = -1000
    return stripped, mask.astype(np.uint8)


def resample_isotropic(
    volume: np.ndarray,
    current_spacing: Tuple[float, ...],
    target_spacing: float = 1.0,
) -> np.ndarray:
    """Resample a volume to isotropic voxel spacing via cubic zoom."""
    zoom_factors = [s / target_spacing for s in current_spacing]
    return ndimage.zoom(volume, zoom_factors, order=1)


def z_score_normalize(
    volume: np.ndarray,
    mask: Optional[np.ndarray] = None,
) -> np.ndarray:
    """Z-score normalisation, optionally restricted to brain-mask voxels."""
    vals  = volume[mask > 0] if mask is not None else volume.flatten()
    mu    = vals.mean()
    sigma = vals.std() + 1e-8
    return (volume - mu) / sigma


def extract_patches_3d(
    volume: np.ndarray,
    patch_size: int = 64,
    stride: int = 32,
) -> Tuple[np.ndarray, List[Tuple]]:
    """
    Sliding-window 3-D patch extraction.
    Returns (patches array [N, C, D, H, W], list of (d1,h1,w1,d2,h2,w2)).
    """
    D, H, W = volume.shape[-3:]
    patches, coords = [], []

    for d in range(0, max(1, D - patch_size + 1), stride):
        for h in range(0, max(1, H - patch_size + 1), stride):
            for w in range(0, max(1, W - patch_size + 1), stride):
                d2 = min(d + patch_size, D)
                h2 = min(h + patch_size, H)
                w2 = min(w + patch_size, W)
                patch = volume[..., d:d2, h:h2, w:w2]
                pd = patch_size - patch.shape[-3]
                ph = patch_size - patch.shape[-2]
                pw = patch_size - patch.shape[-1]
                if pd > 0 or ph > 0 or pw > 0:
                    patch = np.pad(
                        patch,
                        [(0, 0)] * (patch.ndim - 3) + [(0, pd), (0, ph), (0, pw)],
                    )
                patches.append(patch)
                coords.append((d, h, w, d2, h2, w2))

    return np.stack(patches), coords


class CTAugmentor:
    """On-the-fly 3-D augmentation for training."""

    def __init__(self, p: float = 0.5):
        self.p = p

    def random_flip(
        self,
        vol: torch.Tensor,
        seg: torch.Tensor,
    ) -> Tuple[torch.Tensor, torch.Tensor]:
        for axis in [2, 3, 4]:
            if torch.rand(1) < self.p:
                vol = torch.flip(vol, [axis])
                seg = torch.flip(seg, [axis])
        return vol, seg

    def random_rotate90(
        self,
        vol: torch.Tensor,
        seg: torch.Tensor,
    ) -> Tuple[torch.Tensor, torch.Tensor]:
        k = int(torch.randint(0, 4, (1,)).item())
        return torch.rot90(vol, k, [3, 4]), torch.rot90(seg, k, [3, 4])

    def random_intensity_shift(self, vol: torch.Tensor) -> torch.Tensor:
        if torch.rand(1) < self.p:
            shift = (torch.rand(1) - 0.5) * 0.2
            scale = 1.0 + (torch.rand(1) - 0.5) * 0.2
            vol   = vol * scale + shift
        return vol

    def random_gaussian_noise(self, vol: torch.Tensor) -> torch.Tensor:
        if torch.rand(1) < self.p:
            vol = vol + torch.randn_like(vol) * 0.02
        return vol

    def __call__(
        self,
        vol: torch.Tensor,
        seg: torch.Tensor,
    ) -> Tuple[torch.Tensor, torch.Tensor]:
        vol, seg = self.random_flip(vol, seg)
        vol, seg = self.random_rotate90(vol, seg)
        vol      = self.random_intensity_shift(vol)
        vol      = self.random_gaussian_noise(vol)
        return vol, seg


