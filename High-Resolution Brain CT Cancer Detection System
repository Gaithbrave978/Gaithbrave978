   782
   783 def dice_coefficient(
   784     pred: np.ndarray,
   785     target: np.ndarray,
   786     smooth: float = 1e-6,
   787 ) -> float:
   788     p = pred.astype(bool).flatten()
   789     t = target.astype(bool).flatten()
   790     return float((2 * (p & t).sum() + smooth) / (p.sum() + t.sum() + smooth))
   791
   792
   793 def hausdorff_distance_95(
   794     pred: np.ndarray,
   795     target: np.ndarray,
   796     voxel_spacing: Tuple[float, ...] = (1.0, 1.0, 1.0),
   797 ) -> float:
   798     """95th-percentile Hausdorff distance in millimetres."""
   799     from scipy.spatial import cKDTree
   800     pred_pts   = np.argwhere(pred   > 0).astype(float) * np.array(voxel_spacing)
   801     target_pts = np.argwhere(target > 0).astype(float) * np.array(voxel_spacing)
   802     if pred_pts.size == 0 or target_pts.size == 0:
   803         return float("nan")
   804     d_pt = cKDTree(target_pts).query(pred_pts,   workers=-1)[0]
   805     d_tp = cKDTree(pred_pts).query(target_pts,   workers=-1)[0]
   806     return float(max(np.percentile(d_pt, 95), np.percentile(d_tp, 95)))
   807
   808
   809 def sensitivity_specificity(
   810     pred: np.ndarray,
   811     target: np.ndarray,
   812 ) -> Dict[str, float]:
   813     p  = pred.astype(bool).flatten()
   814     t  = target.astype(bool).flatten()
   815     tp = (p & t).sum();  tn = (~p & ~t).sum()
   816     fp = (p & ~t).sum(); fn = (~p &  t).sum()
   817     return dict(
   818         sensitivity = float(tp / (tp + fn + 1e-8)),
   819         specificity = float(tn / (tn + fp + 1e-8)),
   820         ppv         = float(tp / (tp + fp + 1e-8)),
   821         npv         = float(tn / (tn + fn + 1e-8)),
   822     )
   823
   824
   825 def evaluate_segmentation(
   826     pred_mask: np.ndarray,
   827     true_mask: np.ndarray,
   828     spacing: Tuple[float, ...] = (1., 1., 1.),
   829 ) -> Dict:
   830     results = {}
   831     for c, name in enumerate(SEG_NAMES):
   832         if c == 0:
   833             continue
   834         p = (pred_mask == c).astype(np.uint8)
   835         t = (true_mask == c).astype(np.uint8)
   836         results[name] = dict(
   837             dice = dice_coefficient(p, t),
   838             hd95 = hausdorff_distance_95(p, t, spacing),
   839             **sensitivity_specificity(p, t),
   840         )
   841     return results
   842
   843
   844 def evaluate_classification(
   845     y_true: np.ndarray,
   846     y_pred: np.ndarray,
   847     y_prob: np.ndarray,
   848 ) -> Dict:
   849     from sklearn.metrics import (
   850         cohen_kappa_score, confusion_matrix,
   851         classification_report, roc_auc_score,
   852     )
   853     cm     = confusion_matrix(y_true, y_pred)
   854     report = classification_report(y_true, y_pred,
   855                                    target_names=CLS_NAMES, output_dict=True)
   856     kappa  = cohen_kappa_score(y_true, y_pred, weights="quadratic")
   857     try:
   858         auc = (roc_auc_score(y_true, y_prob[:, 1])
   859                if y_prob.shape[1] == 2
   860                else roc_auc_score(y_true, y_prob,
   861                                   multi_class="ovr", average="macro"))
   862     except ValueError:
   863         auc = float("nan")
   864     return dict(confusion_matrix=cm, report=report,
   865                 quadratic_kappa=kappa, roc_auc=auc,
   866                 accuracy=report["accuracy"])
   867
   868
   869 def expected_calibration_error(
   870     y_true: np.ndarray,
   871     y_prob: np.ndarray,
   872     n_bins: int = 15,
   873 ) -> float:
   874     confidences = y_prob.max(axis=1)
   875     predictions = y_prob.argmax(axis=1)
   876     accuracies  = (predictions == y_true).astype(float)
   877     ece = 0.0
   878     for lo, hi in zip(
   879         np.linspace(0, 1, n_bins + 1)[:-1],
   880         np.linspace(0, 1, n_bins + 1)[1:],
   881     ):
   882         mask = (confidences >= lo) & (confidences < hi)
   883         if mask.sum():
   884             ece += mask.mean() * abs(accuracies[mask].mean()
   885                                      - confidences[mask].mean())
   886     return float(ece)
   887
