   200 class CTAugmentor:
   201     """On-the-fly 3-D augmentation for training."""
   202
   203     def __init__(self, p: float = 0.5):
   204         self.p = p
   205
   206     def random_flip(
   207         self,
   208         vol: torch.Tensor,
   209         seg: torch.Tensor,
   210     ) -> Tuple[torch.Tensor, torch.Tensor]:
   211         for axis in [2, 3, 4]:
   212             if torch.rand(1) < self.p:
   213                 vol = torch.flip(vol, [axis])
   214                 seg = torch.flip(seg, [axis])
   215         return vol, seg
   216
   217     def random_rotate90(
   218         self,
   219         vol: torch.Tensor,
   220         seg: torch.Tensor,
   221     ) -> Tuple[torch.Tensor, torch.Tensor]:
   222         k = int(torch.randint(0, 4, (1,)).item())
   223         return torch.rot90(vol, k, [3, 4]), torch.rot90(seg, k, [3, 4])
   224
   225     def random_intensity_shift(self, vol: torch.Tensor) -> torch.Tensor:
   226         if torch.rand(1) < self.p:
   227             shift = (torch.rand(1) - 0.5) * 0.2
   228             scale = 1.0 + (torch.rand(1) - 0.5) * 0.2
   229             vol   = vol * scale + shift
   230         return vol
   231
   232     def random_gaussian_noise(self, vol: torch.Tensor) -> torch.Tensor:
   233         if torch.rand(1) < self.p:
   234             vol = vol + torch.randn_like(vol) * 0.02
   235         return vol
   236
   237     def __call__(
   238         self,
   239         vol: torch.Tensor,
   240         seg: torch.Tensor,
   241     ) -> Tuple[torch.Tensor, torch.Tensor]:
   242         vol, seg = self.random_flip(vol, seg)
   243         vol, seg = self.random_rotate90(vol, seg)
   244         vol      = self.random_intensity_shift(vol)
   245         vol      = self.random_gaussian_noise(vol)
   246         return vol, seg
