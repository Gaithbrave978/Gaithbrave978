   627 #  SECTION 6 — LOSS FUNCTIONS
   628 # ══════════════════════════════════════════════════════════════════════════════
   629
   630 class DiceLoss(nn.Module):
   631     """Soft multi-class Dice loss."""
   632
   633     def __init__(self, smooth: float = 1e-5):
   634         super().__init__()
   635         self.smooth = smooth
   636
   637     def forward(
   638         self,
   639         logits: torch.Tensor,
   640         targets: torch.Tensor,
   641     ) -> torch.Tensor:
   642         probs = torch.softmax(logits, dim=1)
   643         oh    = F.one_hot(targets.long(), probs.size(1)).permute(0, 4, 1, 2, 3).float()
   644         dims  = (0, 2, 3, 4)
   645         inter = (probs * oh).sum(dims)
   646         union = (probs + oh).sum(dims)
   647         return 1.0 - ((2 * inter + self.smooth) / (union + self.smooth)).mean()
   648
   649
   650 class FocalLoss(nn.Module):
   651     """Focal loss — down-weights easy examples to focus on hard ones."""
   652
   653     def __init__(
   654         self,
   655         gamma: float = 2.0,
   656         weight: Optional[torch.Tensor] = None,
   657     ):
   658         super().__init__()
   659         self.gamma  = gamma
   660         self.weight = weight
   661
   662     def forward(
   663         self,
   664         logits: torch.Tensor,
   665         targets: torch.Tensor,
   666     ) -> torch.Tensor:
   667         ce  = F.cross_entropy(logits, targets, weight=self.weight, reduction="none")
   668         p_t = torch.exp(-ce)
   669         return ((1 - p_t) ** self.gamma * ce).mean()
   670
   671
   672 class CombinedSegLoss(nn.Module):
   673     """Dice (0.5) + Cross-Entropy (0.3) + Focal (0.2) combined loss."""
   674
   675     def __init__(
   676         self,
   677         dice_w: float = 0.5,
   678         ce_w:   float = 0.3,
   679         focal_w: float = 0.2,
   680     ):
   681         super().__init__()
   682         self.dice  = DiceLoss()
   683         self.focal = FocalLoss()
   684         self.w     = (dice_w, ce_w, focal_w)
   685
   686     def forward(
   687         self,
   688         logits: torch.Tensor,
   689         targets: torch.Tensor,
   690     ) -> torch.Tensor:
   691         return (
   692             self.w[0] * self.dice(logits, targets)
   693             + self.w[1] * F.cross_entropy(logits, targets.long())
   694             + self.w[2] * self.focal(logits, targets.long())
   695         )
   696
