   253 class ConvBnRelu(nn.Module):
   254     """Conv3d → InstanceNorm → LeakyReLU."""
   255
   256     def __init__(
   257         self,
   258         in_ch: int,
   259         out_ch: int,
   260         kernel: int = 3,
   261         stride: int = 1,
   262         groups: int = 1,
   263     ):
   264         super().__init__()
   265         self.block = nn.Sequential(
   266             nn.Conv3d(
   267                 in_ch, out_ch, kernel,
   268                 stride=stride, padding=kernel // 2,
   269                 groups=groups, bias=False,
   270             ),
   271             nn.InstanceNorm3d(out_ch, affine=True),
   272             nn.LeakyReLU(0.1, inplace=True),
   273         )
   274
   275     def forward(self, x: torch.Tensor) -> torch.Tensor:
   276         return self.block(x)
   277
