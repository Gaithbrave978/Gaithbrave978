# ══════════════════════════════════════════════════════════════════════════════

class BrainCTEnsemble(nn.Module):
    """
    Full diagnostic pipeline in a single nn.Module:

       AttentionUNet3D  ──► seg logits (B, 3, D, H, W)
                                 │
       CancerClassifier3D ◄──────┤  (CT + seg probs concatenated)
                                 │
       MetaFusion MLP   ──► final diagnosis (B, 5)

    Parameters
    ----------
    in_ch       : input CT channels (5 for multi-window)
    seg_classes : segmentation classes (default 3)
    cls_classes : diagnosis classes   (default 5)
    base_ch     : U-Net base channels (32 for production, 8 for unit tests)
    """

    def __init__(
        self,
        in_ch: int = 5,
        seg_classes: int = 3,
        cls_classes: int = 5,
        base_ch: int = 32,
    ):
        super().__init__()
        self.segmentor  = AttentionUNet3D(in_ch, seg_classes, base_ch)
        self.classifier = CancerClassifier3D(in_ch + seg_classes, cls_classes)
        self.fusion     = nn.Sequential(
            nn.Linear(cls_classes + seg_classes, 128),
            nn.GELU(),
            nn.Dropout(0.2),
            nn.Linear(128, cls_classes),
        )

    def forward(
        self,
        x: torch.Tensor,
    ) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
        """
        Returns
        -------
        seg_logits : (B, seg_classes, D, H, W)
        cls_logits : (B, cls_classes)
        fused      : (B, cls_classes)  ← use this for final diagnosis
        """
        seg_logits  = self.segmentor(x)
        seg_probs   = torch.softmax(seg_logits, dim=1)
        cls_input   = torch.cat([x, seg_probs], dim=1)
        cls_logits  = self.classifier(cls_input)
        seg_summary = seg_probs.mean(dim=[2, 3, 4])
        fused       = self.fusion(torch.cat([cls_logits, seg_summary], dim=1))
        return seg_logits, cls_logits, fused


