   378 class EncoderBlock(nn.Module):
   379     def __init__(self, in_ch: int, out_ch: int, dropout: float = 0.1):
   380         super().__init__()
   381         self.conv = nn.Sequential(
   382             ConvBnRelu(in_ch, out_ch),
   383             ResidualBlock(out_ch, dropout),
   384             SEBlock3D(out_ch),
   385         )
   386         self.pool = nn.MaxPool3d(2)
   387
   388     def forward(self, x: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
   389         skip = self.conv(x)
   390         return self.pool(skip), skip
   391
