   893 class BrainCTDataset(Dataset):
   894     """
   895     Torch Dataset that reads from a JSON manifest:
   896
   897     [
   898       {
   899         "id":      "case_001",
   900         "ct":      "path/to/volume.npy",   (D, H, W) float32 HU
   901         "seg":     "path/to/mask.npy",     (D, H, W) uint8 {0,1,2}
   902         "label":   2,                      class index
   903         "spacing": [1.0, 1.0, 1.0]        voxel spacing in mm
   904       }, ...
   905     ]
   906
   907     Compatible with BraTS, TCGA-GBM, and LIDC-IDRI naming conventions.
   908     Foreground-oversampled patch extraction ensures rare tumour voxels
   909     are seen during training.
   910     """
   911
   912     def __init__(
   913         self,
   914         manifest_path: str,
   915         patch_size: int = 64,
   916         patches_per_volume: int = 8,
   917         augment: bool = True,
   918         foreground_oversample: float = 0.67,
   919     ):
   920         with open(manifest_path, encoding="utf-8") as f:
   921             self.records = json.load(f)
   922         self.patch_size = patch_size
   923         self.n_patches  = patches_per_volume
   924         self.augment    = augment
   925         self.fg_rate    = foreground_oversample
   926         self.augmentor  = CTAugmentor(p=0.5)
   927
   928     def __len__(self) -> int:
   929         return len(self.records) * self.n_patches
   930
   931     def _load(self, idx: int) -> Dict:
   932         rec     = self.records[idx // self.n_patches]
   933         hu      = np.load(rec["ct"]).astype(np.float32)
   934         seg     = np.load(rec["seg"]).astype(np.uint8)
   935         spacing = tuple(rec.get("spacing", [1.0, 1.0, 1.0]))
   936         hu, mask = strip_skull(hu)
   937         hu       = z_score_normalize(hu, mask)
   938         return dict(vol5=multi_channel_window(hu), seg=seg,
   939                     label=int(rec["label"]), spacing=spacing)
   940
   941     def _sample_patch(
   942         self,
   943         vol5: np.ndarray,
   944         seg: np.ndarray,
   945     ) -> Tuple[np.ndarray, np.ndarray]:
   946         D, H, W = vol5.shape[1:]
   947         ps      = self.patch_size
   948         if np.random.rand() < self.fg_rate and (seg > 0).any():
   949             fc = np.argwhere(seg > 0)
   950             c  = fc[np.random.randint(len(fc))]
   951         else:
   952             c = [np.random.randint(D), np.random.randint(H), np.random.randint(W)]
   953
   954         d0 = int(np.clip(c[0] - ps // 2, 0, max(0, D - ps)))
   955         h0 = int(np.clip(c[1] - ps // 2, 0, max(0, H - ps)))
   956         w0 = int(np.clip(c[2] - ps // 2, 0, max(0, W - ps)))
   957
   958         vp = vol5[:, d0:d0+ps, h0:h0+ps, w0:w0+ps]
   959         sp = seg[    d0:d0+ps, h0:h0+ps, w0:w0+ps]
   960         pd, ph, pw = ps - vp.shape[1], ps - vp.shape[2], ps - vp.shape[3]
   961         if pd or ph or pw:
   962             vp = np.pad(vp, [(0,0),(0,pd),(0,ph),(0,pw)])
   963             sp = np.pad(sp,         [(0,pd),(0,ph),(0,pw)])
   964         return vp, sp
   965
   966     def __getitem__(self, idx: int) -> Dict[str, torch.Tensor]:
   967         data      = self._load(idx)
   968         vp, sp    = self._sample_patch(data["vol5"], data["seg"])
   969         vol_t     = torch.from_numpy(vp.copy()).float()
   970         seg_t     = torch.from_numpy(sp.copy()).long()
   971         if self.augment:
   972             vol_t, seg_f = self.augmentor(vol_t.unsqueeze(0),
   973                                           seg_t.unsqueeze(0).float())
   974             vol_t = vol_t.squeeze(0)
   975             seg_t = seg_f.squeeze(0).long()
   976         return dict(image=vol_t, seg_mask=seg_t,
   977                     label=torch.tensor(data["label"], dtype=torch.long))
   978
